<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PEFL Season 15 — Results Manager</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #f0c040;
    --gold2: #e0a820;
    --purple: #5c2d91;
    --blue: #1a3a6e;
    --neon: #7b5cff;
    --bg: #0a0a12;
    --card: #13132a;
    --card2: #1a1a35;
    --border: #2a2a4a;
    --text: #e8e8f8;
    --muted: #7070a0;
    --green: #40c07a;
    --red: #c04040;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Barlow', sans-serif; min-height: 100vh; }
  body::before {
    content:''; position:fixed; inset:0;
    background: radial-gradient(ellipse at 20% 0%, rgba(92,45,145,0.2) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 100%, rgba(26,58,110,0.25) 0%, transparent 60%);
    pointer-events:none; z-index:0;
  }
  .wrap { position:relative; z-index:1; max-width:900px; margin:0 auto; padding:0 16px 80px; }

  header { text-align:center; padding:40px 0 28px; border-bottom:2px solid var(--border); margin-bottom:32px; }
  .badge { display:inline-block; background:linear-gradient(135deg,var(--purple),var(--blue)); border:2px solid var(--gold); border-radius:4px; padding:4px 16px; font-family:'Barlow Condensed',sans-serif; font-size:12px; font-weight:700; letter-spacing:3px; color:var(--gold); text-transform:uppercase; margin-bottom:10px; }
  h1 { font-family:'Bebas Neue',sans-serif; font-size:clamp(40px,8vw,72px); letter-spacing:5px; background:linear-gradient(180deg,#fff 0%,var(--gold) 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; line-height:1; }
  .subtitle { font-family:'Barlow Condensed',sans-serif; font-size:16px; font-weight:600; letter-spacing:3px; color:var(--muted); text-transform:uppercase; margin-top:4px; }

  /* WEEK TABS */
  .week-nav { display:flex; gap:6px; flex-wrap:wrap; justify-content:center; margin-bottom:28px; }
  .week-btn { font-family:'Barlow Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:1px; background:var(--card); border:1px solid var(--border); color:var(--muted); padding:7px 13px; border-radius:3px; cursor:pointer; transition:all 0.15s; text-transform:uppercase; }
  .week-btn:hover { border-color:var(--neon); color:var(--text); }
  .week-btn.active { background:linear-gradient(135deg,var(--purple),var(--blue)); border-color:var(--gold); color:var(--gold); }
  .week-btn.has-results { border-color:var(--green); color:var(--green); }
  .week-btn.has-results.active { background:linear-gradient(135deg,#1a4a2a,#1a3a6e); border-color:var(--green); color:var(--green); }

  /* GAME CARDS */
  .games-list { display:flex; flex-direction:column; gap:16px; }

  .game-card { background:var(--card); border:1px solid var(--border); border-radius:8px; overflow:hidden; transition:border-color 0.2s; }
  .game-card:hover { border-color:var(--neon); }
  .game-card.has-result { border-color:var(--green); }

  .game-header { display:flex; align-items:center; padding:14px 18px; border-bottom:1px solid var(--border); gap:12px; cursor:pointer; user-select:none; }
  .game-type-dot { width:8px; height:8px; border-radius:2px; flex-shrink:0; }
  .dot-div { background:var(--gold); }
  .dot-cross { background:var(--neon); }
  .dot-conf { background:var(--muted); }
  .game-matchup { font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; letter-spacing:1px; flex:1; }
  .game-status { font-family:'Barlow Condensed',sans-serif; font-size:12px; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:3px 10px; border-radius:3px; }
  .status-upcoming { background:rgba(112,112,160,0.2); color:var(--muted); }
  .status-final { background:rgba(64,192,122,0.2); color:var(--green); }
  .toggle-icon { color:var(--muted); font-size:14px; transition:transform 0.2s; }
  .game-card.open .toggle-icon { transform:rotate(180deg); }

  .game-body { display:none; padding:18px; }
  .game-card.open .game-body { display:block; }

  /* SCORE ROW */
  .score-row { display:grid; grid-template-columns:1fr auto 1fr; align-items:center; gap:16px; margin-bottom:20px; }
  .score-team { display:flex; flex-direction:column; gap:6px; }
  .score-team.right { align-items:flex-end; }
  .team-label { font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:700; letter-spacing:1px; }
  .score-input-wrap { display:flex; align-items:center; gap:8px; }
  .score-input-wrap.right { flex-direction:row-reverse; }
  .score-input { width:70px; text-align:center; font-family:'Bebas Neue',sans-serif; font-size:36px; background:var(--card2); border:2px solid var(--border); color:var(--gold); border-radius:6px; padding:6px; outline:none; transition:border-color 0.2s; }
  .score-input:focus { border-color:var(--gold); }
  .vs-center { font-family:'Bebas Neue',sans-serif; font-size:24px; color:var(--muted); text-align:center; }

  /* STATS */
  .stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:18px; }
  @media(max-width:600px) { .stats-grid { grid-template-columns:1fr; } }

  .stat-block { background:var(--card2); border:1px solid var(--border); border-radius:6px; padding:12px 14px; }
  .stat-label { font-family:'Barlow Condensed',sans-serif; font-size:11px; font-weight:700; letter-spacing:2px; color:var(--muted); text-transform:uppercase; margin-bottom:8px; }
  .stat-fields { display:flex; flex-direction:column; gap:6px; }
  .stat-row { display:flex; gap:8px; align-items:center; }
  .stat-row label { font-size:12px; color:var(--muted); width:56px; flex-shrink:0; }
  input[type="text"], input[type="number"] {
    flex:1; background:var(--bg); border:1px solid var(--border); color:var(--text);
    font-family:'Barlow',sans-serif; font-size:13px; padding:5px 8px; border-radius:4px; outline:none;
    transition:border-color 0.2s;
  }
  input:focus { border-color:var(--neon); }
  input[type="number"] { width:60px; flex:none; text-align:center; }

  /* BUTTONS */
  .btn-row { display:flex; gap:10px; justify-content:flex-end; }
  .btn { font-family:'Barlow Condensed',sans-serif; font-size:14px; font-weight:700; letter-spacing:1px; text-transform:uppercase; padding:9px 20px; border-radius:4px; cursor:pointer; border:none; transition:all 0.15s; }
  .btn-save { background:linear-gradient(135deg,var(--purple),var(--blue)); color:#fff; border:1px solid var(--gold); }
  .btn-save:hover { opacity:0.85; }
  .btn-clear { background:transparent; color:var(--red); border:1px solid var(--red); }
  .btn-clear:hover { background:rgba(192,64,64,0.1); }

  /* EXPORT PANEL */
  .export-panel { background:var(--card); border:1px solid var(--border); border-radius:8px; padding:20px; margin-top:32px; }
  .export-title { font-family:'Bebas Neue',sans-serif; font-size:24px; letter-spacing:3px; color:var(--gold); margin-bottom:14px; }
  .export-desc { font-size:14px; color:var(--muted); margin-bottom:14px; line-height:1.6; }
  .export-btn { font-family:'Barlow Condensed',sans-serif; font-size:14px; font-weight:700; letter-spacing:1px; text-transform:uppercase; padding:10px 24px; border-radius:4px; cursor:pointer; background:linear-gradient(135deg,var(--purple),var(--blue)); color:var(--gold); border:1px solid var(--gold); transition:opacity 0.15s; }
  .export-btn:hover { opacity:0.85; }
  pre { background:var(--bg); border:1px solid var(--border); border-radius:6px; padding:14px; font-size:12px; color:var(--green); overflow-x:auto; margin-top:14px; max-height:300px; overflow-y:auto; display:none; }
  pre.visible { display:block; }

  .toast { position:fixed; bottom:28px; right:28px; background:var(--green); color:#000; font-family:'Barlow Condensed',sans-serif; font-size:14px; font-weight:700; letter-spacing:1px; padding:10px 20px; border-radius:6px; transform:translateY(80px); opacity:0; transition:all 0.3s; z-index:100; }
  .toast.show { transform:translateY(0); opacity:1; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="badge">Pro Era Football League</div>
    <h1>PEFL S15</h1>
    <div class="subtitle">Results Manager</div>
  </header>

  <div class="week-nav" id="weekNav"></div>
  <div class="games-list" id="gamesList"></div>

  <div class="export-panel">
    <div class="export-title">Export for Discord Bot</div>
    <div class="export-desc">
      When you're ready to push updates to Discord, click below to generate your <code>results.json</code> file.
      Save it next to your bot script, then run <code>node pefl-update-bot.js</code>.
    </div>
    <button class="export-btn" onclick="exportJSON()">📋 Generate results.json</button>
    <pre id="jsonOutput"></pre>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const teams = {
  Chargers:{conf:'PFC',div:'Golden Coast'},Lions:{conf:'PFC',div:'Golden Coast'},Steelers:{conf:'PFC',div:'Golden Coast'},
  Vikings:{conf:'PFC',div:'Colonial'},Bills:{conf:'PFC',div:'Colonial'},Ravens:{conf:'PFC',div:'Colonial'},
  Falcons:{conf:'EFC',div:'Frigid North'},Bears:{conf:'EFC',div:'Frigid North'},'Panthers':{conf:'EFC',div:'Frigid North'},
  Seahawks:{conf:'EFC',div:'Shooting Star'},Colts:{conf:'EFC',div:'Shooting Star'},Rams:{conf:'EFC',div:'Shooting Star'},
};
function getType(a,b){if(teams[a].div===teams[b].div)return'div';if(teams[a].conf!==teams[b].conf)return'cross';return'conf';}

const WEEKS=[
  {week:1,games:[{a:'Chargers',b:'Lions'},{a:'Vikings',b:'Bills'},{a:'Falcons',b:'Bears'},{a:'Seahawks',b:'Colts'},{a:'Steelers',b:'Panthers'},{a:'Ravens',b:'Rams'}]},
  {week:2,games:[{a:'Lions',b:'Steelers'},{a:'Bills',b:'Ravens'},{a:'Bears',b:'Panthers'},{a:'Colts',b:'Rams'},{a:'Chargers',b:'Vikings'},{a:'Falcons',b:'Seahawks'}]},
  {week:3,games:[{a:'Chargers',b:'Steelers'},{a:'Vikings',b:'Ravens'},{a:'Falcons',b:'Panthers'},{a:'Seahawks',b:'Rams'},{a:'Lions',b:'Bills'},{a:'Bears',b:'Colts'}]},
  {week:4,games:[{a:'Chargers',b:'Lions'},{a:'Vikings',b:'Bills'},{a:'Falcons',b:'Bears'},{a:'Seahawks',b:'Colts'},{a:'Ravens',b:'Panthers'},{a:'Steelers',b:'Rams'}]},
  {week:5,games:[{a:'Lions',b:'Steelers'},{a:'Bills',b:'Ravens'},{a:'Bears',b:'Panthers'},{a:'Colts',b:'Rams'},{a:'Chargers',b:'Falcons'},{a:'Vikings',b:'Seahawks'}]},
  {week:6,games:[{a:'Chargers',b:'Steelers'},{a:'Vikings',b:'Ravens'},{a:'Falcons',b:'Panthers'},{a:'Seahawks',b:'Rams'},{a:'Lions',b:'Colts'},{a:'Bills',b:'Bears'}]},
  {week:7,games:[{a:'Chargers',b:'Ravens'},{a:'Lions',b:'Vikings'},{a:'Steelers',b:'Bills'},{a:'Falcons',b:'Colts'},{a:'Bears',b:'Seahawks'},{a:'Panthers',b:'Rams'}]},
  {week:8,games:[{a:'Chargers',b:'Bears'},{a:'Lions',b:'Falcons'},{a:'Steelers',b:'Seahawks'},{a:'Vikings',b:'Panthers'},{a:'Bills',b:'Rams'},{a:'Ravens',b:'Colts'}]},
  {week:9,games:[{a:'Chargers',b:'Colts'},{a:'Lions',b:'Panthers'},{a:'Steelers',b:'Falcons'},{a:'Vikings',b:'Rams'},{a:'Bills',b:'Seahawks'},{a:'Ravens',b:'Bears'}]},
  {week:10,games:[{a:'Chargers',b:'Seahawks'},{a:'Lions',b:'Ravens'},{a:'Steelers',b:'Colts'},{a:'Vikings',b:'Bears'},{a:'Bills',b:'Panthers'},{a:'Falcons',b:'Rams'}]},
  {week:11,games:[{a:'Chargers',b:'Rams'},{a:'Lions',b:'Seahawks'},{a:'Steelers',b:'Bears'},{a:'Vikings',b:'Falcons'},{a:'Bills',b:'Colts'},{a:'Ravens',b:'Panthers'}]},
  {week:12,games:[{a:'Chargers',b:'Panthers'},{a:'Lions',b:'Bears'},{a:'Steelers',b:'Seahawks'},{a:'Vikings',b:'Colts'},{a:'Bills',b:'Falcons'},{a:'Ravens',b:'Rams'}]},
  {week:13,games:[{a:'Chargers',b:'Bills'},{a:'Lions',b:'Rams'},{a:'Steelers',b:'Panthers'},{a:'Vikings',b:'Bears'},{a:'Ravens',b:'Seahawks'},{a:'Falcons',b:'Colts'}]},
];

// Storage key
const STORAGE_KEY = 'pefl_s15_results';
let results = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
let currentWeek = 1;

function gameKey(week, a, b) { return `w${week}_${a}_${b}`; }

function saveToStorage() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(results));
}

function weekHasResults(weekNum) {
  const wk = WEEKS.find(w => w.week === weekNum);
  return wk.games.some(g => results[gameKey(weekNum, g.a, g.b)]?.final);
}

function renderNav() {
  const nav = document.getElementById('weekNav');
  nav.innerHTML = '';
  WEEKS.forEach(({week}) => {
    const btn = document.createElement('button');
    const hasRes = weekHasResults(week);
    btn.className = `week-btn${week===currentWeek?' active':''}${hasRes?' has-results':''}`;
    btn.textContent = `Wk ${week}`;
    btn.onclick = () => { currentWeek = week; renderNav(); renderGames(); };
    nav.appendChild(btn);
  });
}

function renderGames() {
  const list = document.getElementById('gamesList');
  list.innerHTML = '';
  const wkData = WEEKS.find(w => w.week === currentWeek);

  wkData.games.forEach(({a, b}) => {
    const key = gameKey(currentWeek, a, b);
    const saved = results[key] || {};
    const type = getType(a, b);
    const dotClass = {div:'dot-div', cross:'dot-cross', conf:'dot-conf'}[type];
    const isFinal = !!saved.final;

    const card = document.createElement('div');
    card.className = `game-card${isFinal?' has-result':''}`;
    card.id = `card-${key}`;

    card.innerHTML = `
      <div class="game-header" onclick="toggleCard('${key}')">
        <div class="game-type-dot ${dotClass}"></div>
        <div class="game-matchup">${a} <span style="color:var(--muted)">vs</span> ${b}</div>
        ${isFinal ? `<div class="game-status status-final">✅ Final: ${saved.scoreA}–${saved.scoreB}</div>` : `<div class="game-status status-upcoming">⏳ Upcoming</div>`}
        <div class="toggle-icon">▼</div>
      </div>
      <div class="game-body">
        <!-- SCORE -->
        <div class="score-row">
          <div class="score-team">
            <div class="team-label">${a}</div>
          </div>
          <div style="display:flex;align-items:center;gap:10px;">
            <input class="score-input" type="number" min="0" id="scoreA-${key}" value="${saved.scoreA ?? ''}" placeholder="0">
            <div class="vs-center">—</div>
            <input class="score-input" type="number" min="0" id="scoreB-${key}" value="${saved.scoreB ?? ''}" placeholder="0">
          </div>
          <div class="score-team right">
            <div class="team-label">${b}</div>
          </div>
        </div>

        <!-- STATS GRID -->
        <div class="stats-grid">
          <div class="stat-block">
            <div class="stat-label">🏈 Passing Leader</div>
            <div class="stat-fields">
              <div class="stat-row"><label>Player</label><input type="text" id="pass_name-${key}" value="${saved.pass_name||''}" placeholder="e.g. J. Allen"></div>
              <div class="stat-row"><label>Team</label><input type="text" id="pass_team-${key}" value="${saved.pass_team||''}" placeholder="Bills"></div>
              <div class="stat-row"><label>Yards</label><input type="number" id="pass_yds-${key}" value="${saved.pass_yds||''}" placeholder="0"></div>
              <div class="stat-row"><label>TDs</label><input type="number" id="pass_td-${key}" value="${saved.pass_td||''}" placeholder="0"></div>
              <div class="stat-row"><label>INTs</label><input type="number" id="pass_int-${key}" value="${saved.pass_int||''}" placeholder="0"></div>
            </div>
          </div>
          <div class="stat-block">
            <div class="stat-label">🏃 Rushing Leader</div>
            <div class="stat-fields">
              <div class="stat-row"><label>Player</label><input type="text" id="rush_name-${key}" value="${saved.rush_name||''}" placeholder="e.g. D. Henry"></div>
              <div class="stat-row"><label>Team</label><input type="text" id="rush_team-${key}" value="${saved.rush_team||''}" placeholder="Ravens"></div>
              <div class="stat-row"><label>Yards</label><input type="number" id="rush_yds-${key}" value="${saved.rush_yds||''}" placeholder="0"></div>
              <div class="stat-row"><label>TDs</label><input type="number" id="rush_td-${key}" value="${saved.rush_td||''}" placeholder="0"></div>
              <div class="stat-row"><label>Carries</label><input type="number" id="rush_car-${key}" value="${saved.rush_car||''}" placeholder="0"></div>
            </div>
          </div>
          <div class="stat-block">
            <div class="stat-label">🎯 Receiving Leader</div>
            <div class="stat-fields">
              <div class="stat-row"><label>Player</label><input type="text" id="rec_name-${key}" value="${saved.rec_name||''}" placeholder="e.g. T. Hill"></div>
              <div class="stat-row"><label>Team</label><input type="text" id="rec_team-${key}" value="${saved.rec_team||''}" placeholder="Chargers"></div>
              <div class="stat-row"><label>Yards</label><input type="number" id="rec_yds-${key}" value="${saved.rec_yds||''}" placeholder="0"></div>
              <div class="stat-row"><label>TDs</label><input type="number" id="rec_td-${key}" value="${saved.rec_td||''}" placeholder="0"></div>
              <div class="stat-row"><label>Rec</label><input type="number" id="rec_rec-${key}" value="${saved.rec_rec||''}" placeholder="0"></div>
            </div>
          </div>
          <div class="stat-block">
            <div class="stat-label">⭐ Game MVP</div>
            <div class="stat-fields">
              <div class="stat-row"><label>Player</label><input type="text" id="mvp_name-${key}" value="${saved.mvp_name||''}" placeholder="Player name"></div>
              <div class="stat-row"><label>Team</label><input type="text" id="mvp_team-${key}" value="${saved.mvp_team||''}" placeholder="Team"></div>
              <div class="stat-row"><label>Note</label><input type="text" id="mvp_note-${key}" value="${saved.mvp_note||''}" placeholder="e.g. 3 TD, 280 yds"></div>
            </div>
          </div>
        </div>

        <div class="btn-row">
          <button class="btn btn-clear" onclick="clearGame('${key}')">Clear</button>
          <button class="btn btn-save" onclick="saveGame('${key}','${a}','${b}')">Save Result</button>
        </div>
      </div>
    `;
    list.appendChild(card);
  });
}

function toggleCard(key) {
  const card = document.getElementById(`card-${key}`);
  card.classList.toggle('open');
}

function val(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }

function saveGame(key, a, b) {
  const scoreA = parseInt(val(`scoreA-${key}`));
  const scoreB = parseInt(val(`scoreB-${key}`));
  if (isNaN(scoreA) || isNaN(scoreB)) { showToast('⚠️ Enter both scores first!'); return; }

  results[key] = {
    final: true,
    teamA: a, teamB: b,
    scoreA, scoreB,
    winner: scoreA > scoreB ? a : scoreB > scoreA ? b : 'TIE',
    pass_name: val(`pass_name-${key}`), pass_team: val(`pass_team-${key}`),
    pass_yds: val(`pass_yds-${key}`), pass_td: val(`pass_td-${key}`), pass_int: val(`pass_int-${key}`),
    rush_name: val(`rush_name-${key}`), rush_team: val(`rush_team-${key}`),
    rush_yds: val(`rush_yds-${key}`), rush_td: val(`rush_td-${key}`), rush_car: val(`rush_car-${key}`),
    rec_name: val(`rec_name-${key}`), rec_team: val(`rec_team-${key}`),
    rec_yds: val(`rec_yds-${key}`), rec_td: val(`rec_td-${key}`), rec_rec: val(`rec_rec-${key}`),
    mvp_name: val(`mvp_name-${key}`), mvp_team: val(`mvp_team-${key}`), mvp_note: val(`mvp_note-${key}`),
  };
  saveToStorage();
  renderNav();
  renderGames();
  // Re-open card
  setTimeout(() => {
    const card = document.getElementById(`card-${key}`);
    if (card) card.classList.add('open');
  }, 10);
  showToast('✅ Result saved!');
}

function clearGame(key) {
  delete results[key];
  saveToStorage();
  renderNav();
  renderGames();
  showToast('🗑️ Cleared');
}

function exportJSON() {
  const output = document.getElementById('jsonOutput');
  const json = JSON.stringify(results, null, 2);
  output.textContent = json;
  output.classList.add('visible');

  // Also trigger download
  const blob = new Blob([json], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'results.json'; a.click();
  URL.revokeObjectURL(url);
  showToast('📥 results.json downloaded!');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

renderNav();
renderGames();
</script>
</body>
</html>
